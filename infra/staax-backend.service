[Unit]
Description=STAAX Backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/staax/backend
Environment="PATH=/home/ubuntu/staax/backend/venv/bin"
ExecStart=/home/ubuntu/staax/backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
